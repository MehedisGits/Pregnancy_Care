<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <include layout="@layout/second_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/Signs">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/signsTitle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/missedPeriods"
                android:textColor="@color/textColor"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold">

            </TextView>

            <View
                android:id="@+id/divider31"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_margin="@dimen/_6sdp"
                android:background="?android:attr/listDivider" />

            <TextView
                android:id="@+id/signsText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/morningC"
                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp">


            </TextView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>